# DigitalWallet backend environment template.
# Copy to backend/.env and fill values. Secret-bearing variables (marked REQUIRED)
# MUST NOT have committed defaults — see .claude/rules/security.md §1.

# --- Postgres -----------------------------------------------------------------
DB_USER=digitalwallet
DB_PASSWORD=                                # REQUIRED (no committed default)
DB_NAME=digitalwallet
POSTGRES_HOST_PORT=5432
# DB_URL is used when running the backend OUTSIDE the compose network
# (`./mvnw quarkus:dev`). Inside the `--profile app` container the value is
# overridden to `jdbc:postgresql://postgres:5432/<DB_NAME>`.
DB_URL=jdbc:postgresql://localhost:5432/digitalwallet

# --- Kafka --------------------------------------------------------------------
KAFKA_HOST_PORT=9092
KAFKA_ADVERTISED_HOST=localhost
KAFKA_BOOTSTRAP_SERVERS=localhost:9092

# --- Redis --------------------------------------------------------------------
REDIS_HOST_PORT=6379
REDIS_URL=redis://localhost:6379

# --- Backend container --------------------------------------------------------
BACKEND_HOST_PORT=8080
BACKEND_IMAGE_TAG=local
QUARKUS_PROFILE=prod
# Comma-separated allow-list consumed by quarkus.http.cors.origins in `prod`.
# Defaults cover the Vite dev server and the dockerised frontend (see frontend/env.template).
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:8090

# --- JWT (ADR #1, ES256) ------------------------------------------------------
# Generate ES256 keypair locally; do NOT commit. See .claude/rules/security.md §2.
JWT_PUBLIC_KEY=                             # REQUIRED
JWT_PRIVATE_KEY=                            # REQUIRED (dev/prod only; absent in test)

# --- LLM (ADR #2 — provider TBD) ---------------------------------------------
LLM_API_KEY=                                # REQUIRED once ADR #2 closes
LLM_BASE_URL=

# --- Fraud thresholds (docs/architecture/README.md §7) ------------------------
FRAUD_VELOCITY_WINDOW_SECONDS=60
FRAUD_VELOCITY_THRESHOLD=5
FRAUD_VOLUME_WINDOW_SECONDS=3600
FRAUD_VOLUME_THRESHOLD=50000
FRAUD_SUSPENSION_BREACH_COUNT=3
FRAUD_SUSPENSION_WINDOW_SECONDS=3600

# --- Rate limits --------------------------------------------------------------
RATELIMIT_TRANSFER_PER_MINUTE=10
RATELIMIT_ADVISOR_PER_HOUR=5

# --- FX cache -----------------------------------------------------------------
FX_RATE_TTL_SECONDS=300

# --- Frontend tier (only used to widen ALLOWED_ORIGINS) ----------------------
FRONTEND_HOST_PORT=8090
