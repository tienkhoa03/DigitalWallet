# DigitalWallet frontend environment template.
# Copy to frontend/.env and adjust values. There are NO secret-bearing variables in
# this tier — any value prefixed with VITE_ is readable in the browser bundle
# (.claude/rules/security.md §1).

# --- Host binding -------------------------------------------------------------
# Host port that exposes the nginx container. The default avoids clashing with the
# Vite dev server (5173) and the Quarkus backend (8080).
FRONTEND_HOST_PORT=8090
FRONTEND_IMAGE_TAG=local

# --- Build-time public config -------------------------------------------------
# Where the bundle sends REST traffic. Default /api routes through the nginx
# reverse proxy in this image; override only when the backend is reached directly
# (e.g. cross-host dev with CORS allow-listed in ALLOWED_ORIGINS).
VITE_API_BASE_URL=/api
