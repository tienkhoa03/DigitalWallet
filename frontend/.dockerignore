# Keep the build context small and safe. Mirrors .gitignore plus build artefacts.
node_modules/
dist/
.vite/
*.tsbuildinfo

# Tests — Playwright E2E specs are not needed in the image.
tests/
playwright-report/
test-results/

# Editor / IDE
.idea/
.vscode/
*.swp
*.swo
.DS_Store

# Secrets and local env — security.md §1
.env
.env.*
!.env.template

# Logs
*.log
npm-debug.log*
pnpm-debug.log*

# Docker meta
Dockerfile
.dockerignore
docker-compose*.yml
docker-compose*.yaml
nginx.conf
README.md
