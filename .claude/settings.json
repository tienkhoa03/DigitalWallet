{
  "permissions": {
    "deny": [
      "Read(**/.env)",
      "Read(**/.env.*)",
      "Read(**/.envrc)",
      "Read(**/*.env)",
      "Read(**/secrets/**)",
      "Read(**/secrets.*)",
      "Read(**/*.pem)",
      "Read(**/*.key)",
      "Read(**/*.p12)",
      "Read(**/*.pfx)",
      "Read(**/*.jks)",
      "Read(**/*.keystore)",
      "Read(**/credentials.json)",
      "Read(**/*credentials*.json)",
      "Read(**/.trello.env)",
      "Read(**/.aws/credentials)",
      "Read(**/.ssh/id_*)",
      "Edit(**/.env)",
      "Edit(**/.env.*)",
      "Edit(**/.envrc)",
      "Edit(**/*.env)",
      "Edit(**/secrets/**)",
      "Edit(**/secrets.*)",
      "Edit(**/*.pem)",
      "Edit(**/*.key)",
      "Edit(**/credentials.json)",
      "Edit(**/*credentials*.json)",
      "Write(**/.env)",
      "Write(**/.env.*)",
      "Write(**/.envrc)",
      "Write(**/*.env)",
      "Write(**/secrets/**)",
      "Write(**/secrets.*)",
      "Write(**/*.pem)",
      "Write(**/*.key)",
      "Write(**/credentials.json)",
      "Write(**/*credentials*.json)",
      "Bash(cat *.env*)",
      "Bash(cat .env*)",
      "Bash(cat **/.env*)",
      "Bash(cat **/secrets/**)",
      "Bash(cat **/*.pem)",
      "Bash(cat **/*.key)",
      "Bash(cat **/credentials*)",
      "Bash(printenv:*)",
      "Bash(env)",
      "Bash(echo $TRELLO_TOKEN)",
      "Bash(echo $TRELLO_KEY)",
      "Bash(echo $*_TOKEN)",
      "Bash(echo $*_KEY)",
      "Bash(echo $*_SECRET)",
      "Bash(echo $*_PASSWORD)"
    ]
  }
}
