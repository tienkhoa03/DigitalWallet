# Trello API credentials — TEMPLATE
#
# These power BOTH:
#   - the Trello MCP server in .mcp.json (reads ${TRELLO_API_KEY} / ${TRELLO_TOKEN})
#   - scripts/trello.sh and scripts/seed_trello_board.py
#
# Setup:
#   1. cp trello.env.example .env        # (or trello.env — both are gitignored)
#   2. Fill TRELLO_API_KEY and TRELLO_TOKEN below.
#   3. Export them in the shell that launches `claude` so the MCP server can read them:
#        set -a; source ./.env; set +a   # then start: claude
#      (or add the two exports to ~/.bashrc)
#
# Where to get the values:
#   - TRELLO_API_KEY: https://trello.com/app-key  (Power-Up admin → API key)
#   - TRELLO_TOKEN:   the "Token" link on the same flow → Authorize → copy
#
# Security:
#   - Real values must NEVER be committed (.env / trello.env are gitignored).
#   - The token has full access to your Trello account — treat it as a password.
#   - Revoke at https://trello.com/<username>/account → "Power-Ups and integrations".
#
# Note: scripts/trello.sh also accepts the legacy name TRELLO_KEY as a fallback,
# but TRELLO_API_KEY is the canonical name used by .mcp.json and the MCP server.

export TRELLO_API_KEY=""
export TRELLO_TOKEN=""

# Default board for this project. NOT a secret — it only tells Claude which
# board to target. The SessionStart hook (scripts/trello-board-context.sh, wired
# in .claude/settings.json) reads this and injects it as context, so every
# mcp__trello__ call uses this board without you restating it each session.
export TRELLO_BOARD_ID="6a2239c1f8f0ad9bd0bc5f4f"   # "Personal Project - Digital Wallet" (short link BBVddj3q)
