# Trello API credentials — TEMPLATE
#
# Setup:
#   1. cp trello.env.example trello.env
#   2. Fill TRELLO_KEY and TRELLO_TOKEN below
#   3. source ./trello.env   (do this in each new shell, or add to ~/.bashrc)
#
# Where to get the values:
#   - TRELLO_KEY:   top of https://trello.com/app-key (must be logged in)
#   - TRELLO_TOKEN: click the "Token" link on the same page → Authorize → copy
#
# Security:
#   - trello.env (without .example) is gitignored. Never commit real values.
#   - Token has full access to your Trello account — treat as a password.
#   - Revoke at https://trello.com/<username>/account → Power-Ups and integrations.

export TRELLO_KEY=""
export TRELLO_TOKEN=""
